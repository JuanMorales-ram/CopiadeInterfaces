<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:contentDescription="@string/todo">


    <!-- LOGO -->



    <ImageView
        android:id="@+id/LogoPrincipal"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@drawable/ic_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="24dp"/>

    <!-- NOMBRE APP -->
    <TextView
        android:id="@+id/TituloPrincipalApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nombredelaapp"
        android:textColor="@android:color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/LogoPrincipal"
        app:layout_constraintTop_toTopOf="@id/LogoPrincipal"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"/>

    <!-- SUBTEXTO -->
    <TextView
        android:id="@+id/DescripcionLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/la_aventura_est_por_iniciar_por_favor_inicia_sesi_n"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="italic"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/LogoPrincipal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"/>

    <!-- ICONO USER Y PASSWORD -->

    <!-- INPUT EMAIL -->

    <ImageView
        android:id="@+id/iconosVerticalLogin"
        android:layout_width="66dp"
        android:layout_height="115dp"
        android:layout_marginTop="80dp"
        android:scaleType="fitXY"
        android:src="@drawable/ic_icono"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.092"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/DescripcionLogin" />


    <!-- REGISTRATE -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIngresarLogin"
        android:layout_width="250dp"
        android:layout_height="60dp"
        android:layout_marginBottom="204dp"
        android:text="@string/ingresar"
        android:textColor="#E24A3B"
        android:textSize="24sp"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="40dp"
        app:layout_constraintBottom_toBottomOf="@+id/MensajeRegistro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#E24A3B"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/RecuperarContraseñaLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:text="@string/recupera_tu_contrase_a"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/btnGoogleIngresoLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnIngresarLogin"
        app:layout_constraintVertical_bias="0.114" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogleIngresoLogin"
        android:layout_width="290dp"
        android:layout_height="56dp"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="76dp"
        android:text="@string/ingresa_con_google"
        android:textColor="@android:color/black"
        android:textSize="18sp"

        app:backgroundTint="@android:color/white"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_google_icon"
        app:iconGravity="textStart"

        app:iconPadding="12dp"
        app:iconTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintHorizontal_bias="0.246"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#E24A3B"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/MensajeRegistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/no_tienes_cuenta_reg_strate"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnGoogleIngresoLogin" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/CampoUsuarioLogin"
        android:layout_width="244dp"
        android:layout_height="48dp"
        android:layout_marginTop="272dp"
        android:background="@drawable/ic_input_rounded"
        android:hint="@string/primer_campo"
        android:padding="12dp"
        android:textColor="#000000"
        android:textColorHint="#888888"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.682"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/CampoContraseñaLogin"
        android:layout_width="244dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/ic_input_rounded"
        android:hint="@string/segundo_campo"
        android:padding="12dp"
        android:textColor="#000000"
        android:textColorHint="#888888"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.682"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/CampoUsuarioLogin" />


</androidx.constraintlayout.widget.ConstraintLayout>